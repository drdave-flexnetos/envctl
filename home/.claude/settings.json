{
  "skillListingBudgetFraction": 0.05,
  "permissions": {
    "git worktree add": "alwaysAllow",
    "git branch -D": "alwaysAllow",
    "git push": "alwaysAllow",
    "gh pr create": "alwaysAllow",
    "gh pr merge": "alwaysAllow",
    "skipDangerousModePermissionPrompt": true,
    "skipWorkflowUsageWarning": true,
    "theme": "dark"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/drdave/.local/bin/icm hook post"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/drdave/.local/bin/icm hook compact"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/drdave/.local/bin/icm hook pre"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "true"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "true"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "'/home/drdave/Desktop/meta/weave/target/release/weave' hook session"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/drdave/.local/bin/icm hook start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "true"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "'/home/drdave/Desktop/meta/weave/target/release/weave' hook wake"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "vox \"Done.\""
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "true"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "'/home/drdave/Desktop/meta/weave/target/release/weave' hook prompt"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/drdave/.local/bin/icm hook prompt"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "'/home/drdave/Desktop/meta/weave/target/release/weave' hook wake"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/drdave/Desktop/meta/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "gitkb@gitkb": true,
    "harness@harness-marketplace": true,
    "meta@gitkb": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "gitkb": {
      "source": {
        "source": "directory",
        "path": "/home/drdave/Desktop/meta/claude-plugins"
      }
    },
    "harness-marketplace": {
      "source": {
        "source": "directory",
        "path": "/home/drdave/Desktop/meta/harness_hub/harness"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
