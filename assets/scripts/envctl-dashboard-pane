#!/usr/bin/env bash
# envctl-dashboard-pane — per-pane launcher for the meta mission-control zellij
# dashboard (generated by `envctl dashboard`). The generated KDL points each pane's
# `command=` at this script with the repo id as its single argument.
#
# Responsibility: establish the per-repo MESH IDENTITY environment (weave +
# repowire), then either `exec` an IDLE agent session for that repo or drop to a
# shell. It does NOT start an autonomous loop. By default a pane now drops to a
# plain shell; a human must explicitly opt in to start `claude` by setting
# $ENVCTL_DASHBOARD_AUTO_CLAUDE=1 (or by running the `envctl-open-claude`
# wrapper). The legacy $ENVCTL_DASHBOARD_PANE_CMD override still works for
# escalating to forge-loop / env-install-loop.
#
# Config asset (not engine logic): pure shell, sanctioned like the other
# assets/scripts/*.sh wrappers. No language drift — the GENERATOR is Rust.
#
# ── Mesh design (decision: register on BOTH weave AND repowire) ─────────────────
# Each pane registers a STABLE, UNIQUE per-repo identity on BOTH meshes:
#   * weave    — the cross-identity message bus (heartbeats, to:all broadcasts)
#   * repowire — the per-repo peer/job bus (directed peer messaging, jobs)
# We export identity hints from $META_REPO; the launched `claude` session's MCP
# baseline (weave + repowire servers) brings the identity up on connect. The
# launcher OWNS uniqueness (one identity per pane/repo) so peers never collide.
#
# Cross-pane "mail": weave's SELF-inbox is invisible to a session (a session does
# not see its own messages), so cross-pane coordination uses weave `to:all`
# broadcasts and/or repowire directed peers — NOT weave self-sends. (See the
# CLAUDE.md change-history note on weave self-inbox invisibility.)
#
# ── Broker-unification follow-on (NOT implemented here) ─────────────────────────
# North star: unify weave + repowire + broker behind a single mesh broker so a pane
# registers ONE identity and both transports are served from it. That is a
# documented follow-on (see docs/ROADMAP.md / the dashboard plan); until then this
# launcher dual-registers (weave + repowire) with the SAME derived identity so the
# two views stay consistent and the later unification is a drop-in swap.
set -euo pipefail

# Arg 1 = the repo id (the mesh-identity seed). "overview" = the free shell pane.
REPO_ID="${1:-overview}"

# --- mesh identity (weave + repowire hints, consumed by each session's MCP baseline) ---
export META_REPO="$REPO_ID"
export DASHBOARD_PANE=1

# Stable, unique identity per pane, derived from $META_REPO so weave/repowire peers
# don't collide. Same string on BOTH meshes so the two views describe one peer.
MESH_IDENTITY="dashboard:${META_REPO}"
export MESH_IDENTITY
# weave identity hints (cross-identity bus). Multiple env names are exported so the
# MCP baseline picks up whichever its weave server reads.
export WEAVE_IDENTITY="$MESH_IDENTITY"
export WEAVE_SESSION="$MESH_IDENTITY"
export WEAVE_PEER="$MESH_IDENTITY"
# repowire identity hints (per-repo peer/job bus).
export REPOWIRE_PEER="$MESH_IDENTITY"
export REPOWIRE_IDENTITY="$MESH_IDENTITY"
export REPOWIRE_REPO="$META_REPO"

# The overview pane is just a free shell (mission control), not an agent session.
# It still carries a mesh identity so it can observe to:all broadcasts.
if [ "$REPO_ID" = "overview" ]; then
  exec "${SHELL:-/usr/bin/env bash}"
fi

# --- the per-pane command (overridable to escalate) ---
# Priority:
#   1. $ENVCTL_DASHBOARD_PANE_CMD (legacy escape hatch to forge-loop etc.)
#   2. $ENVCTL_DASHBOARD_AUTO_CLAUDE=1 + claude on PATH -> start idle claude
#   3. otherwise -> drop to a plain shell (human must explicitly start claude)
if [ -n "${ENVCTL_DASHBOARD_PANE_CMD:-}" ]; then
  exec bash -c "$ENVCTL_DASHBOARD_PANE_CMD"
fi

if [ "${ENVCTL_DASHBOARD_AUTO_CLAUDE:-0}" = "1" ] && command -v claude >/dev/null 2>&1; then
  exec claude
fi

# Default: idle shell. The mesh identity env vars remain exported so a later
# `envctl-open-claude` invocation in this pane still registers the correct peer.
exec "${SHELL:-/usr/bin/env bash}"
