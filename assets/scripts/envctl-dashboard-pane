#!/usr/bin/env bash
# envctl-dashboard-pane — per-pane launcher for the meta mission-control zellij
# dashboard (generated by `envctl dashboard`). The generated KDL points each pane's
# `command=` at this script with the repo id as its single argument.
#
# Responsibility: establish the per-repo mesh identity environment, then `exec` an
# IDLE agent session for that repo. It does NOT start an autonomous loop — opening
# a pane drops you into an idle `claude` you can drive by hand (escalatable to
# forge-loop / env-install-loop later via $ENVCTL_DASHBOARD_PANE_CMD).
#
# Config asset (not engine logic): pure shell, sanctioned like the other
# assets/scripts/*.sh wrappers. No language drift — the GENERATOR is Rust.
set -euo pipefail

# Arg 1 = the repo id (the mesh-identity seed). "overview" = the free shell pane.
REPO_ID="${1:-overview}"

# --- mesh identity (weave + repowire hints, consumed by each session's MCP baseline) ---
export META_REPO="$REPO_ID"
export DASHBOARD_PANE=1
# Stable, unique identity per pane so weave/repowire peers don't collide. Each pane
# gets a deterministic id derived from the repo; the launcher owns uniqueness.
export WEAVE_IDENTITY="dashboard:${REPO_ID}"
export REPOWIRE_PEER="dashboard:${REPO_ID}"

# The overview pane is just a free shell (mission control), not an agent session.
if [ "$REPO_ID" = "overview" ]; then
  exec "${SHELL:-/usr/bin/env bash}"
fi

# --- the per-pane command (overridable to escalate) ---
# Default: an idle interactive `claude` session in this repo. Override with
# ENVCTL_DASHBOARD_PANE_CMD to run e.g. a forge-loop or env-install-loop instead.
if [ -n "${ENVCTL_DASHBOARD_PANE_CMD:-}" ]; then
  exec bash -c "$ENVCTL_DASHBOARD_PANE_CMD"
fi

if command -v claude >/dev/null 2>&1; then
  exec claude
else
  echo "envctl-dashboard-pane: 'claude' not found on PATH for $REPO_ID — dropping to a shell." >&2
  exec "${SHELL:-/usr/bin/env bash}"
fi
